{
  "name": "vertical-agent-forge",
  "version": "0.3.0",
  "description": "Production-grade self-improvement control plane for OpenClaw vertical agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbdtf202-cyber/vertical-agent-forge.git"
  },
  "homepage": "https://mbdtf202-cyber.github.io/vertical-agent-forge/",
  "bugs": {
    "url": "https://github.com/mbdtf202-cyber/vertical-agent-forge/issues"
  },
  "type": "module",
  "bin": {
    "vertical-agent-forge": "./bin/vertical-agent-forge.mjs"
  },
  "files": [
    "bin/",
    "kit/",
    "docs/",
    "scripts/install.mjs",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "doctor": "node ./bin/vertical-agent-forge.mjs doctor",
    "install:local": "node ./bin/vertical-agent-forge.mjs install",
    "activate:local": "node ./bin/vertical-agent-forge.mjs activate",
    "uninstall:local": "node ./bin/vertical-agent-forge.mjs uninstall",
    "site:screenshots": "node ./scripts/generate-demo.mjs",
    "package": "node ./scripts/package-release.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "openclaw",
    "agent",
    "multi-agent",
    "self-improving-agent",
    "continuous-worker",
    "hot-plug",
    "vertical-agent",
    "toolkit"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "json5": "2.2.3"
  },
  "devDependencies": {
    "playwright": "1.54.2"
  }
}
