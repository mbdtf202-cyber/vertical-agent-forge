{
  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace-vertical-forge",
      maxConcurrent: 2,
      timeoutSeconds: 600,
      subagents: {
        maxConcurrent: 8,
        maxSpawnDepth: 2,
        maxChildrenPerAgent: 6,
        runTimeoutSeconds: 240,
      },
    },
    list: [
      {
        id: "app-main",
        default: true,
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Main",
          theme: "user-facing vertical application agent",
        },
        skills: ["vertical-service-core", "forge-shared-protocol", "forge-artifact-contracts"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/domain",
            "knowledge/domain/compiled",
            "knowledge/policies",
            "knowledge/glossary",
            "knowledge/action-catalog",
            "knowledge/routing",
            "forge/memory",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-forge",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Forge",
          theme: "continuous improvement orchestrator",
        },
        skills: [
          "continuous-worker",
          "forge-shared-protocol",
          "forge-artifact-contracts",
          "forge-orchestrator",
        ],
        heartbeat: {
          every: "15m",
          target: "none",
          ackMaxChars: 80,
          suppressToolErrorWarnings: true,
          lightContext: true,
        },
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/domain",
            "knowledge/domain/compiled",
            "knowledge/policies",
            "knowledge/glossary",
            "knowledge/action-catalog",
            "knowledge/evals",
            "knowledge/routing",
            "knowledge/playbooks",
            "knowledge/schemas",
            "forge/templates",
            "forge/memory",
            "forge/eval/reports",
            "forge/monitoring",
            "forge/releases",
            "forge/incidents",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        subagents: {
          allowAgents: [
            "app-domain-compiler",
            "app-worker",
            "app-evaluator",
            "app-critic",
            "app-adversary",
            "app-promoter",
            "app-deployer",
            "app-observer",
            "app-archivist",
          ],
        },
        tools: {
          allow: [
            "read",
            "write",
            "edit",
            "task",
            "memory_search",
            "memory_get",
            "sessions_spawn",
            "subagents",
            "agents_list",
            "sessions_list",
            "sessions_history",
          ],
        },
      },
      {
        id: "app-domain-compiler",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Domain Compiler",
          theme: "raw business materials into compiled domain pack",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-domain-compiler"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/sources",
            "knowledge/domain",
            "knowledge/policies",
            "knowledge/glossary",
            "knowledge/action-catalog",
            "knowledge/evals",
            "knowledge/routing",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-worker",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Worker",
          theme: "candidate improvement builder",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-worker"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/domain",
            "knowledge/policies",
            "knowledge/action-catalog",
            "knowledge/playbooks",
            "knowledge/schemas",
            "forge/templates",
            "forge/memory",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-evaluator",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Evaluator",
          theme: "regression, shadow, canary, and connector evaluation runner",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-evaluator"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/evals",
            "knowledge/routing",
            "knowledge/schemas",
            "forge/templates",
            "forge/eval/reports",
            "forge/monitoring",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-critic",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Critic",
          theme: "blind evaluator",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-critic"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/domain",
            "knowledge/policies",
            "knowledge/playbooks",
            "knowledge/schemas",
            "forge/templates",
            "forge/eval/reports",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-adversary",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Adversary",
          theme: "counterexample hunter",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-adversary"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/domain",
            "knowledge/policies",
            "knowledge/playbooks",
            "knowledge/schemas",
            "forge/templates",
            "forge/eval/adversarial",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-promoter",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Promoter",
          theme: "release gatekeeper",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-promoter"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/routing",
            "knowledge/playbooks",
            "knowledge/schemas",
            "forge/templates",
            "forge/eval/reports",
            "forge/releases",
            "forge/memory",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-deployer",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Deployer",
          theme: "auto promotion, rollout, and rollback executor",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-deployer"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/action-catalog",
            "knowledge/routing",
            "knowledge/schemas",
            "forge/templates",
            "forge/releases",
            "forge/monitoring",
            "forge/incidents",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-observer",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Observer",
          theme: "post-promotion monitoring and incident aggregation",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-observer"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/routing",
            "knowledge/schemas",
            "forge/monitoring",
            "forge/incidents",
            "forge/releases",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
      {
        id: "app-archivist",
        workspace: "~/.openclaw/workspace-vertical-forge",
        identity: {
          name: "Archivist",
          theme: "durable knowledge distiller",
        },
        skills: ["forge-shared-protocol", "forge-artifact-contracts", "forge-archivist"],
        memorySearch: {
          enabled: true,
          sources: ["memory"],
          extraPaths: [
            "knowledge/domain",
            "knowledge/policies",
            "knowledge/playbooks",
            "knowledge/schemas",
            "forge/templates",
            "forge/memory",
            "forge/eval/reports",
            "forge/releases",
          ],
        },
        sandbox: {
          mode: "all",
          scope: "agent",
        },
        tools: {
          allow: ["read", "write", "edit", "memory_search", "memory_get"],
        },
      },
    ],
  },
  tools: {
    sessions: {
      visibility: "tree",
    },
    subagents: {
      tools: {
        deny: ["browser", "cron", "gateway", "message"],
      },
    },
    web: {
      search: {
        enabled: true,
        provider: "perplexity",
      },
    },
  },
}
